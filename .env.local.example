# ─── Solana RPC ──────────────────────────────────────────────────────────────
# Server-side RPC (used to build + verify transactions)
SOLANA_RPC_URL=https://rpc.solanatracker.io/public

# Client-side RPC (used by wallet adapter in the browser)
NEXT_PUBLIC_SOLANA_RPC_URL=https://rpc.solanatracker.io/public

# ─── Agent Token ─────────────────────────────────────────────────────────────
# The pump.fun token mint address for your tokenized agent
# Replace with your real mint address before deploying!
AGENT_TOKEN_MINT_ADDRESS=So11111111111111111111111111111111111111112

# ─── Payment Currency ────────────────────────────────────────────────────────
# SOL (wrapped): So11111111111111111111111111111111111111112
# USDC:          EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
CURRENCY_MINT=So11111111111111111111111111111111111111112


# ─── Price ───────────────────────────────────────────────────────────────────
# Amount in smallest unit: SOL uses 9 decimals (100000000 = 0.1 SOL)
PRICE_AMOUNT=100000000
